# ── Google Cloud / Gemini ─────────────────────────
GOOGLE_CLOUD_PROJECT=vg-pp-001
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_API_KEY=
# Model used across all agents
LLM_MODEL=gemini-2.5-flash

# ── MCP Server URLs (comma-separated for multi-server) ─
# Clients read MCP_SERVER_URLS for multi-server support.
# MCP_SERVER_URL kept for backward compatibility (single server).
MCP_SERVER_URLS=http://localhost:9002/mcp,http://localhost:9003/mcp
MCP_SERVER_URL=http://localhost:9002/mcp
WEATHER_SERVER_URL=http://localhost:9002/mcp
STOCK_SERVER_URL=http://localhost:9003/mcp
# Or point clients at the gateway (aggregates all servers):
# MCP_SERVER_URLS=http://localhost:8000/mcp

# ── Keycloak OIDC (OAuth for MCP servers) ────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=mcp
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Set to "true" to require OAuth on MCP servers
MCP_AUTH_ENABLED=false

# ── Credentials file (centralized secrets) ───────
# All client IDs/secrets live in infra/credentials.yaml
CREDENTIALS_FILE=infra/credentials.yaml

# ── Registry DB ──────────────────────────────────
DATABASE_URL=sqlite:///./registry.db

# ── Gateway ──────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# ── Registry backend ─────────────────────────────
REGISTRY_HOST=0.0.0.0
REGISTRY_PORT=8080

# ── Status checker interval (seconds) ────────────
STATUS_CHECK_INTERVAL=60
